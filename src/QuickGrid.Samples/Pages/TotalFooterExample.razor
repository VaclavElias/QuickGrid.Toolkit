@page "/total-footer-example"

<ExampleInfo Title="Total Footer"
             SourceFile="TotalFooterExample.razor"
             Lead="Add an automatic totals row to a QuickGridWrapper.">
    <p>
        Set a <code>TotalFooter</code> with <code>IsTotalFooter = true</code> and give the wrapper an
        <code>Id</code>. The toolkit sums every numeric column and renders the totals in a footer row.
        Columns added with <code>AddNumber</code> / <code>AddStyledNumber</code> participate automatically;
        set <code>CalculateTotal</code> on a column to force a total on or off.
    </p>
    <ul>
        <li>The footer is drawn by a small ES module shipped with the toolkit (<code>quickGridToolkit.js</code>), imported automatically — but it only renders when the wrapper has an <code>Id</code>, since that becomes the table's <code>id</code>.</li>
        <li>This builds directly on the <a href="users-grid-wrapper">QuickGridWrapper</a> example; only <code>TotalFooter</code> and <code>Id</code> are added.</li>
        <li>Data comes from <code>SalesService</code> (a list of <code>SalesDto</code>) so the numeric columns have something to total.</li>
    </ul>
</ExampleInfo>

<QuickGridWrapper Items="@_items.AsQueryable()"
                  TotalFooter="_totalFooter"
                  Id="id-total-footer-example"
                  ColumnManager="_columnManager" />

@code {
    private List<SalesDto> _items = new();
    private ColumnManager<SalesDto> _columnManager = new();
    private TotalFooter _totalFooter = new() { IsTotalFooter = true };
    private decimal _totalAmount;

    protected override void OnInitialized()
    {
        _items = SalesService.GetSales();
        _totalAmount = _items.Sum(item => item.TotalAmount);

        _columnManager.AddIndexColumn();
        _columnManager.Add(new() { Property = p => p.Id });
        _columnManager.AddSimple(p => p.Region, fullTitle: "Region");
        _columnManager.AddSimple(p => p.Product, fullTitle: "Product");
        _columnManager.AddStyledNumber<decimal>(p => p.TotalAmount, "Amount", fullTitle: "Total Amount", format: "N2", @class: "text-end");
        _columnManager.AddStyledNumber<decimal>(p => p.TotalAmount / _totalAmount, "Average", fullTitle: "Average Amount", format: "N2", @class: "text-end");
        _columnManager.AddStyledNumber<decimal>(p => p.TotalAmount / _totalAmount, "Average %", fullTitle: "Average Amount %", format: "P2", @class: "text-end");
    }
}
